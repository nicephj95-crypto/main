# Shared/default environment values.
# For local-only overrides, copy values into .env.local instead.

# PostgreSQL (Railway에서 자동 주입됨)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# App
PORT=4002
NODE_ENV=development
JWT_SECRET="change-this-to-a-long-random-secret"
CORS_ORIGINS="http://localhost:5173"
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14
FRONTEND_BASE_URL="http://localhost:5173"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="HMUS <no-reply@example.com>"

# External APIs
KAKAO_REST_API_KEY=""
NAVER_MAP_CLIENT_ID=""
NAVER_MAP_CLIENT_SECRET=""
USE_NAVER_DISTANCE=false

# 인성 연동 (값 없으면 자동 비활성 — "연동 설정이 없습니다" 에러 반환)
INSUNG_BASE_URL="https://인성API도메인"
INSUNG_M_CODE=""
INSUNG_CC_CODE=""
INSUNG_USER_ID=""
INSUNG_UKEY=""

# 화물24 연동 (값 없으면 자동 비활성 — "연동 설정이 없습니다" 에러 반환)
CALL24_BASE_URL="https://api.15660088.com:18091"
CALL24_API_KEY=""
CALL24_AES_KEY=""
CALL24_AES_IV=""
CALL24_ADDR_API_PATH="/api/order/addr"

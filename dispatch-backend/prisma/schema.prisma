// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 여기부터 enum/모델들 ---

enum UserRole {
  ADMIN
  DISPATCHER
  SALES
  CLIENT
}

enum RequestStatus {
  PENDING       // 접수중
  DISPATCHING   // 배차중(기사 찾는 중)
  ASSIGNED      // 배차완료
  IN_TRANSIT    // 운행중
  COMPLETED     // 완료
  CANCELLED     // 취소
}

enum LoadMethod {
  FORKLIFT        // 지게차
  MANUAL          // 수작업
  SUDOU_SUHAEJUNG // 수도움/수해중
  HOIST           // 호이스트
  CRANE           // 크레인
  CONVEYOR        // 컨베이어
}

enum RequestType {
  NORMAL      // 기본
  URGENT      // 긴급
  DIRECT      // 퀵/훈척
  ROUND_TRIP  // 왕복
}

enum PaymentMethod {
  CREDIT        // 신용(월마감)
  CARD          // 카드 결제
  CASH_PREPAID  // 현금 선불
  CASH_COLLECT  // 현금 착불
}

enum VehicleGroup {
  MOTORCYCLE
  DAMAS
  LABO
  ONE_TON_PLUS
}

enum AddressType {
  PICKUP
  DROPOFF
  BOTH
}

enum SignupRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           Int        @id @default(autoincrement())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(CLIENT)

  companyName  String?
  phone        String?    // 연락처
  department   String?    // 부서
  isActive     Boolean    @default(true)  // 재직중=true, 퇴사=false

  requests     Request[]  @relation("RequestCreatedBy")
  addressBook  AddressBook[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens RefreshToken[]
  reviewedSignupRequests SignupRequest[] @relation("SignupRequestReviewedBy")

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model SignupRequest {
  id           Int                 @id @default(autoincrement())
  name         String
  email        String              @unique
  passwordHash String
  status       SignupRequestStatus @default(PENDING)
  reviewedById Int?
  reviewedBy   User?               @relation("SignupRequestReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([status])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model CompanyName {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  createdAt        DateTime          @default(now())
  groupDepartments GroupDepartment[]
  groupContacts    GroupContact[]
  ownedRequests    Request[]         @relation("RequestOwnerCompany")
}

model GroupDepartment {
  id         Int            @id @default(autoincrement())
  groupId     Int
  group       CompanyName   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String
  contacts    GroupContact[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([groupId, name])
  @@index([groupId])
}

model GroupContact {
  id           Int             @id @default(autoincrement())
  groupId      Int
  group        CompanyName     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  departmentId Int
  department   GroupDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name         String
  position     String?
  phone        String?
  email        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([groupId])
  @@index([departmentId])
  @@index([name])
}

model AddressBook {
  id            Int         @id @default(autoincrement())
  userId        Int
  user          User        @relation(fields: [userId], references: [id])

  businessName  String?
  placeName     String      // 출발지명/도착지명(센터/거점 이름)
  type          AddressType
  address       String
  addressDetail String?
  contactName   String?
  contactPhone  String?
  lunchTime     String?
  memo          String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  images        AddressBookImage[]
  pickupRequests Request[]  @relation("RequestPickupAddressBook")
  dropoffRequests Request[] @relation("RequestDropoffAddressBook")
}

model AddressBookImage {
  id            Int        @id @default(autoincrement())
  addressBookId Int
  addressBook   AddressBook @relation(fields: [addressBookId], references: [id])

  storageProvider String  @default("LOCAL")
  storageKey      String
  publicUrl       String?

  originalName    String
  mimeType        String
  sizeBytes       Int
  width           Int?
  height          Int?
  kind            String   @default("original")
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())

  @@index([addressBookId, sortOrder])
}

model Driver {
  id              Int        @id @default(autoincrement())
  name            String
  phone           String

  vehicleNumber   String?
  vehicleGroup    VehicleGroup?
  vehicleTonnage  Float?
  vehicleBodyType String?
  region          String?
  memo            String?

  assignments     RequestDriverAssignment[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Request {
  id                      Int           @id @default(autoincrement())

  // 출발지(상차지)
  pickupPlaceName         String
  pickupAddress           String
  pickupAddressDetail     String?
  pickupContactName       String?
  pickupContactPhone      String?
  pickupAddressBookId     Int?
  pickupAddressBook       AddressBook?   @relation("RequestPickupAddressBook", fields: [pickupAddressBookId], references: [id], onDelete: SetNull)
  pickupMethod            LoadMethod
  pickupIsImmediate       Boolean       @default(false)
  pickupDatetime          DateTime?

  // 도착지(하차지)
  dropoffPlaceName        String
  dropoffAddress          String
  dropoffAddressDetail    String?
  dropoffContactName      String?
  dropoffContactPhone     String?
  dropoffAddressBookId    Int?
  dropoffAddressBook      AddressBook?   @relation("RequestDropoffAddressBook", fields: [dropoffAddressBookId], references: [id], onDelete: SetNull)
  dropoffMethod           LoadMethod
  dropoffIsImmediate      Boolean       @default(false)
  dropoffDatetime         DateTime?

  // 차량 선택
  vehicleGroup            VehicleGroup?
  vehicleTonnage          Float?
  vehicleBodyType         String?

  // 화물 내용
  cargoDescription        String?

  // 특이사항 / 기사 요청사항
  requestType             RequestType    @default(NORMAL)
  driverNote              String?
  orderNumber             String?

  // 결제 / 거리 / 요금
  paymentMethod           PaymentMethod?
  distanceKm              Float?
  quotedPrice             Int?
  actualFare              Int?           // 실운임 (기사에게 지급하는 운임)
  billingPrice            Int?           // 청구가 (고객에게 청구하는 금액)

  // 업체 정보 (ADMIN/DISPATCHER/SALES가 업체 선택 시 저장)
  ownerCompanyId          Int?
  ownerCompany            CompanyName?   @relation("RequestOwnerCompany", fields: [ownerCompanyId], references: [id], onDelete: SetNull)
  targetCompanyName       String?
  targetCompanyContactName String?
  targetCompanyContactPhone String?

  // 알림 설정
  pickupNotify            Boolean        @default(false)
  dropoffNotify           Boolean        @default(false)

  // 인성 연동
  insungSerialNumber      String?
  insungSyncStatus        String?        @default("NONE") // NONE | PENDING | SUCCESS | FAILED
  insungSyncedAt          DateTime?
  insungLastError         String?
  insungLastLocationLat   Float?
  insungLastLocationLon   Float?
  insungLastLocationAt    DateTime?

  // 화물24 연동
  call24OrdNo             String?
  call24SyncStatus        String?        @default("NONE") // NONE | PENDING | SUCCESS | FAILED
  call24SyncedAt          DateTime?
  call24LastError         String?
  call24LastLocationLat   Float?
  call24LastLocationLon   Float?
  call24LastLocationAt    DateTime?

  // 외부 연동 금액 (인성/화물24 공통)
  externalEstimatedPrice  Int?
  externalSentPrice       Int?
  externalPlatform        String?

  // 상태 / 생성자
  status                  RequestStatus  @default(PENDING)
  createdById             Int?
  createdBy               User?          @relation("RequestCreatedBy", fields: [createdById], references: [id])

  assignments             RequestDriverAssignment[]
  images                  RequestImage[]

  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  @@index([ownerCompanyId])
  @@index([pickupAddressBookId])
  @@index([dropoffAddressBookId])
}

model RequestImage {
  id            Int      @id @default(autoincrement())
  requestId      Int
  request        Request  @relation(fields: [requestId], references: [id])

  storageProvider String  @default("LOCAL")
  storageKey      String
  publicUrl       String?

  originalName    String
  mimeType        String
  sizeBytes       Int
  width           Int?
  height          Int?
  kind            String   @default("original")
  sortOrder       Int      @default(0)

  createdAt       DateTime @default(now())

  @@index([requestId, sortOrder])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?
  userName   String?
  userRole   String?
  action     String   // CREATE, UPDATE, DELETE, APPROVE, REJECT, STATUS_CHANGE, IMAGE_UPLOAD
  resource   String   // REQUEST, USER, ADDRESS_BOOK, GROUP
  resourceId Int?
  target     String?
  detail     String?  // JSON serialized detail
  createdAt  DateTime @default(now())

  @@index([resource, resourceId])
  @@index([resource, resourceId, target, createdAt])
  @@index([createdAt])
}

model RequestDriverAssignment {
  id         Int      @id @default(autoincrement())
  requestId  Int
  driverId   Int

  request    Request  @relation(fields: [requestId], references: [id])
  driver     Driver   @relation(fields: [driverId], references: [id])

  assignedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isActive        Boolean  @default(true)
  endedAt         DateTime?
  endedReason     String?
  memo            String?
  actualFare      Int?      // 실운임 이력 (대외비)
  billingPrice    Int?      // 청구가 이력

  // 추가 배차정보 필드
  extraFare        Int?     // 추가요금 (대외비)
  extraFareReason  String?  // 추가사유 (대외비)
  codRevenue       Int?     // 착불수익 (대외비)
  customerMemo     String?  // 업무메모 (화주 공개)
  internalMemo     String?  // 내부용 메모 (대외비)

  // 활성 배차 1건 보장은 PostgreSQL partial unique index로 SQL migration에서 강제한다.
  @@index([requestId, isActive])
  @@index([requestId, assignedAt])
}
